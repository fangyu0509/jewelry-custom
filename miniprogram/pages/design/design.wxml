<!--pages/design/design.wxml-->
<view class="container">
  <!-- 头部标题 -->
  <view class="header">
    <text class="title">开始您的手串设计之旅</text>
    <text class="subtitle">选择您喜欢的设计方式</text>
  </view>

  <!-- 我的设计卡片 -->
  <view class="card my-design-card" bindtap="goToMyDesign">
    <view class="card-content">
      <text class="card-title">我的设计</text>
      <text class="card-subtitle">查看已保存的设计记录</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 设计方式选项 -->
  <view class="options-list">
    <!-- 自由定制手串 -->
    <view class="option-card" bindtap="goToCustom">
      <image class="option-icon" src="https://picsum.photos/240/240?random=30" mode="aspectFit" />
      <text class="option-title">自由定制手串</text>
      <text class="option-desc">从零开始，发挥您的创意，自由选择材料形状和尺寸，打造您最满意的手串</text>
    </view>

    <!-- 选购单珠 -->
    <view class="option-card" bindtap="goToBeads">
      <image class="option-icon" src="https://picsum.photos/240/240?random=31" mode="aspectFit" />
      <text class="option-title">选购单珠</text>
      <text class="option-desc">想凑凑单珠？没问题！快来选几个宝贝带回家吧，满 40 元即可包邮</text>
    </view>

    <!-- 设计广场 -->
    <view class="option-card" bindtap="goToGallery">
      <image class="option-icon" src="https://picsum.photos/240/240?random=32" mode="aspectFit" />
      <text class="option-title">设计广场</text>
      <text class="option-desc">汲取灵感，查看来自世界各地的珠宝设计，选择一款作为您的蓝图</text>
    </view>
  </view>
</view>
