/* pages/design/design.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  padding: 50rpx 30rpx 30rpx;
}

.title {
  font-size: 40rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.card {
  margin: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.my-design-card {
  background: linear-gradient(135deg, #E53935 0%, #D32F2F 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-content {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

.options-list {
  padding: 0 30rpx;
}

.option-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.option-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.option-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  text-align: center;
}
