/* pages/design/design.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 15rpx;
}

.picker {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.input {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.textarea {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  min-height: 200rpx;
}

.upload-btn {
  background-color: #FFD700;
  color: #333;
  font-size: 28rpx;
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  margin-right: 15rpx;
  display: inline-block;
}

.price-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price {
  font-size: 48rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.submit-btn {
  background-color: #FFD700;
  color: #333;
  font-size: 32rpx;
  font-weight: 500;
  padding: 30rpx;
  border-radius: 16rpx;
  border: none;
}
