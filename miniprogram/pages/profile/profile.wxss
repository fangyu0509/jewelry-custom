/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  padding: 60rpx 30rpx 40rpx;
  background-color: #fff;
}

.welcome {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.card {
  margin: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.design-card {
  background: linear-gradient(135deg, #E53935 0%, #D32F2F 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-content {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card-list {
  margin: 0 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.cart-icon {
  color: #FF9800;
}

.location-icon {
  color: #FF5722;
}

.help-icon {
  color: #03A9F4;
}

.terms-icon {
  color: #FF5722;
}

.list-text {
  display: flex;
  flex-direction: column;
}

.list-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.list-subtitle {
  font-size: 24rpx;
  color: #999;
}

.list-arrow {
  font-size: 40rpx;
  color: #ccc;
}
