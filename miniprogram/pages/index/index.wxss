/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 分类滚动 */
.category-scroll {
  background: #fff;
  padding: 20rpx 0;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.category-item.active {
  background: #FFD700;
  color: #fff;
}

/* 产品列表 */
.product-list {
  padding: 20rpx;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  color: #ff4444;
  font-size: 36rpx;
  font-weight: bold;
}

.price-symbol {
  font-size: 24rpx;
  margin-right: 4rpx;
}

/* 加载状态 */
.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
