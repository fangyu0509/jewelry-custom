<!--pages/index/index.wxml-->
<scroll-view scroll-y class="container">
  <!-- 品牌 Logo -->
  <view class="brand-section">
    <image class="brand-logo" src="https://picsum.photos/300/300?random=1" mode="aspectFit" />
    <text class="brand-name">养个石头</text>
    <text class="brand-slogan">只做天然珠宝</text>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToCustom">
      <image class="entry-icon" src="https://picsum.photos/200/200?random=2" mode="aspectFit" />
      <text class="entry-title">DIY-CUSTOM</text>
      <text class="entry-subtitle">设计手串</text>
    </view>
    <view class="entry-item" bindtap="goToGoods">
      <image class="entry-icon" src="https://picsum.photos/200/200?random=3" mode="aspectFit" />
      <text class="entry-title">MUST-HAVE</text>
      <text class="entry-subtitle">好物</text>
    </view>
  </view>

  <!-- 客服广告横幅 -->
  <view class="banner" bindtap="contactService">
    <image class="banner-image" src="https://picsum.photos/800/400?random=4" mode="aspectFill" />
  </view>

  <!-- 设计广场 -->
  <view class="design-plaza">
    <view class="plaza-header" bindtap="goToPlaza">
      <text class="plaza-title">设计广场</text>
      <text class="plaza-subtitle">从来自世界各地的设计中寻找灵感</text>
      <text class="plaza-arrow">›</text>
    </view>

    <!-- 商品列表 -->
    <view class="product-list">
      <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="goToProduct" data-id="{{item.id}}">
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-material">{{item.material}}</text>
          <text class="product-desc">{{item.description}}</text>
          <button class="view-btn" size="mini">查看实物</button>
        </view>
        <image class="product-image" src="{{item.image}}" mode="aspectFill" />
      </view>
    </view>
  </view>

  <!-- 加载完成 -->
  <view class="load-more">
    <text class="load-text">已加载全部数据</text>
  </view>
</scroll-view>
